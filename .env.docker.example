# Docker dev environment — copy to .env.docker and adjust if needed
DJANGO_SECRET_KEY=docker-dev-secret-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001
TRANSCRIPTION_PROVIDER=stub
KNOWLEDGE_NOTE_PROVIDER=stub

# AI Summary provider (stub | openai_compatible)
SUMMARY_PROVIDER=stub
AI_HUB_BASE_URL=https://adesso-ai-hub.3asabc.de/v1
AI_HUB_API_KEY=
AI_HUB_MODEL=qwen-3.5-122b-sovereign
AI_HUB_EMBEDDING_MODEL=

# faster-whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
