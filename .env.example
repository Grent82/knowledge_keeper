# Backend
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002,http://127.0.0.1:3003
DATABASE_URL=postgresql://knowledge_keeper:knowledge_keeper@localhost:5432/knowledge_keeper
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI providers (stub | openai_compatible)
TRANSCRIPTION_PROVIDER=stub
KNOWLEDGE_NOTE_PROVIDER=stub
SUMMARY_PROVIDER=stub
AI_HUB_BASE_URL=https://adesso-ai-hub.3asabc.de/v1
AI_HUB_API_KEY=
AI_HUB_MODEL=qwen-3.5-122b-sovereign
AI_HUB_EMBEDDING_MODEL=

# faster-whisper (when TRANSCRIPTION_PROVIDER=faster_whisper)
# Model sizes: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
